generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}



/*
|--------------------------------------------------------------------------
| USUARIOS
|--------------------------------------------------------------------------
*/

model Usuarios {

  id                   String   @id @default(uuid())

  nombre               String

  apellidos            String

  identificacion       String   @unique

  correo               String   @unique

  telefono             String?

  password             String

  token_recuperacion   String?

  expira_recuperacion  DateTime?

  activo               Boolean  @default(true)

  creado_en            DateTime @default(now())

  actualizado_en       DateTime @updatedAt

  @@map("usuarios")
}



/*
|--------------------------------------------------------------------------
| CATEGORÍAS INGREDIENTES
|--------------------------------------------------------------------------
*/

model CategoriasIngrediente {

  id             Int      @id @default(autoincrement())

  nombre         String   @unique

  activo         Boolean  @default(true)

  creado_en      DateTime @default(now())

  ingredientes   Ingredientes[]

  @@map("categorias_ingrediente")
}



/*
|--------------------------------------------------------------------------
| INGREDIENTES
|--------------------------------------------------------------------------
*/

model Ingredientes {

  id                String   @id @default(uuid())

  categoria_id      Int?

  categoria         CategoriasIngrediente? @relation(fields: [categoria_id], references: [id])

  nombre            String   @unique

  descripcion       String?

  activo            Boolean  @default(true)

  creado_en         DateTime @default(now())

  actualizado_en    DateTime @updatedAt

  recetas           RecetasProductoIngrediente[]

  @@map("ingredientes")
}



/*
|--------------------------------------------------------------------------
| PRODUCTOS FINALES
|--------------------------------------------------------------------------
*/

model ProductosFinales {

  id                        String   @id @default(uuid())

  nombre                    String

  descripcion               String?

  imagen_url                String? @db.Text

  cantidad_ml               Decimal  @db.Decimal(10,2)

  porcentaje_ganancia       Decimal  @db.Decimal(5,2)

  porcentaje_perdida        Decimal  @default(0) @db.Decimal(5,2)

  activo                    Boolean  @default(true)

  creado_en                 DateTime @default(now())

  actualizado_en            DateTime @updatedAt

  recetas                   RecetasProductoIngrediente[]

  recipientes               ProductoRecipiente[]

  gastos                    Gastos[]

  @@map("productos_finales")
}



/*
|--------------------------------------------------------------------------
| RECETA PRODUCTO INGREDIENTE
|--------------------------------------------------------------------------
*/

model RecetasProductoIngrediente {

  producto_id         String

  ingrediente_id      String

  cantidad_ml         Decimal  @db.Decimal(10,2)

  precio_por_ml       Decimal  @db.Decimal(12,4)

  creado_en           DateTime @default(now())

  producto            ProductosFinales @relation(fields: [producto_id], references: [id], onDelete: Cascade)

  ingrediente         Ingredientes @relation(fields: [ingrediente_id], references: [id])

  activo Boolean @default(true)

  @@id([producto_id, ingrediente_id])

  @@map("recetas_producto_ingrediente")
}



/*
|--------------------------------------------------------------------------
| TIPOS RECIPIENTES
|--------------------------------------------------------------------------
*/

model TiposRecipientes {

  id                     String   @id @default(uuid())

  nombre                 String   @unique

  valor                  Decimal  @db.Decimal(14,2)

  tamano_recipiente      Decimal  @db.Decimal(14,2)

  activo                 Boolean  @default(true)

  productos              ProductoRecipiente[]

  @@map("tipos_recipientes")
}



/*
|--------------------------------------------------------------------------
| PRODUCTO RECIPIENTE
|--------------------------------------------------------------------------
*/

model ProductoRecipiente {

  producto_id          String

  recipiente_id        String

  cantidad_unidades    Int @default(0)

  activo               Boolean @default(true)

  producto             ProductosFinales @relation(fields: [producto_id], references: [id])

  recipiente           TiposRecipientes @relation(fields: [recipiente_id], references: [id])

  @@id([producto_id, recipiente_id])

  @@map("producto_recipiente")
}



/*
|--------------------------------------------------------------------------
| GASTOS
|--------------------------------------------------------------------------
*/

model Gastos {

  id                   String   @id @default(uuid())

  producto_id          String?

  producto             ProductosFinales? @relation(fields: [producto_id], references: [id])

  nombre               String

  descripcion          String?

  valor                Decimal  @db.Decimal(14,2)

  activo               Boolean  @default(true)

  fecha_gasto          DateTime @default(now())

  creado_en            DateTime @default(now())

  actualizado_en       DateTime @updatedAt

  @@map("gastos")
}